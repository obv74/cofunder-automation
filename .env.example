# CoFoundersLab scraper bot – copy to .env and adjust as needed.
# All values are optional; defaults are shown.

# --- Modes ---
# Auto-repost rule is built in: if best matched post position is 4+, the bot reposts.

# Default headless mode for scrape (true = invisible browser). Overridden by: python main.py scrape --headless
HEADLESS=true

# --- Timeouts & retries ---
# Login wait timeout in milliseconds (e.g. 300000 = 5 minutes).
LOGIN_TIMEOUT_MS=300000

# Session validation retries and delay (seconds) between retries.
RETRY_ATTEMPTS=3
RETRY_DELAY=5

# --- 24/7 / performance (increase on slow machines or flaky network) ---
# Selector wait timeout in ms (e.g. 20000 = 20s; avoids "Timeout 5000ms exceeded").
SELECTOR_TIMEOUT_MS=20000
# Page load (goto/reload) timeout in ms.
PAGE_LOAD_TIMEOUT_MS=45000
# Seconds between feed checks.
MONITOR_INTERVAL_SEC=30
# Max monitoring cycles: 0 = unlimited (continuous). Use 1+ for limited runs (e.g. scheduled task).
# Or use CLI: python main.py scrape --headless --checks 0 (run once, exit) or --checks 5 (5 checks then exit).
# MAX_MONITOR_CHECKS=0
# Extra seconds to wait after feed reload for content to render (reduce timeouts).
FEED_RENDER_WAIT_SEC=5
# Retries when creating a post fails (e.g. timeout) before next cycle.
CREATE_POST_RETRIES=3
RETRY_DELAY_CREATE_POST_SEC=5

# --- Logging ---
# Set true for verbose DEBUG lines (noisy over 24/7).
DEBUG=false
# Log level: DEBUG, INFO, WARNING, ERROR (default INFO).
LOG_LEVEL=INFO
# Optional: path to log file. If set, logs also go to this file (rotating, 2 MB, 5 backups).
# LOG_FILE=logs/cofunder.log

# --- Telegram alerts (when errors occur) ---
# Set true to send error alerts to Telegram.
TELEGRAM_ALERTS_ENABLED=false
# Bot token from @BotFather.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Chat ID (user or group). Get it from @userinfobot or by sending a message to your bot and visiting https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_CHAT_ID=123456789
# Set to false only if you get SSL CERTIFICATE_VERIFY_FAILED (e.g. behind corporate proxy/firewall with SSL inspection)
# TELEGRAM_SSL_VERIFY=true

# --- Optional: login URL (change only if the site URL changes) ---
# LOGIN_URL=https://cofounderslab.com/login
